    "Bedrock_Portfolio_Agent" : {
      "Type" : "Job:AWS Bedrock",
      "ConnectionProfile" : "MOL-BEDROCK-CP",
      "Flow Id" : "<BEDROCK_FLOW_ID>",
      "Alias" : "<BEDROCK_FLOW_ALIAS_ID>",
      "Flow Text Input" : "\"The Q1 2026 data is staged in S3 (using the file Current_Portfolio.csv). Conduct a fragility benchmark against the 2018 stress period and generate a PDF strategic rebalancing proposal for Q2. I need to see the chart of recommended sector shifts both here and inside the PDF; please render all charts at 100 DPI to ensure the PDF is optimized for archival. Finally, archive that PDF to S3 via the ReportArchiver tool and provide me with the exact secure download link.\"%4E",
      "Input Node Name" : "FlowInputNode",
      "Initial Node Output Name" : "document",
      "Latency" : "Standard",
      "Show Execution Events" : "checked",
      "Host" : "",
      "CreatedBy" : "<CREATED_BY_EMAIL>",
      "Description" : "Runs the Bedrock AI analysis workflow using the market snapshot and portfolio data, generates strategic rebalance recommendations, and creates the PDF repo",
      "RunAs" : "MOL-BEDROCK-CP",
      "Application" : "SM_BEDROCK",
