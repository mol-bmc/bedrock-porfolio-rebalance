    "Snowflake_Extract_SP500" : {
      "Type" : "Job:Database:EmbeddedQuery",
      "Query" : "USE SCHEMA SP500_CURATED.MARKET;\\n\\nCOPY INTO @SP500_CURATED.GOVERNANCE.SP500_S3_STAGE/market_snapshot.json\\nFROM (\\n    SELECT ARRAY_AGG(\\n        OBJECT_CONSTRUCT(\\n            'date', DATE,\\n            'risk_score', RISK_SCORE,\\n            'vol_change', VOL_CHANGE,\\n            'breadth_change', BREADTH_CHANGE,\\n            'avg_volatility', AVG_VOLATILITY,\\n            'pct_overbought', PCT_OVERBOUGHT,\\n            'return_dispersion', RETURN_DISPERSION,\\n            'dispersion_change', DISPERSION_CHANGE,\\n            'pct_above_ma30', PCT_ABOVE_MA30,\\n            'avg_bb_width', AVG_BB_WIDTH\\n        )\\n    ) AS market_data\\n    FROM SP500_CURATED.MARKET.VW_MARKET_TREND_CONTEXT\\n)\\nFILE_FORMAT = (TYPE = 'JSON' COMPRESSION = NONE)\\nOVERWRITE = TRUE\\nSINGLE = TRUE;",
      "ConnectionProfile" : "SNOWFLAKE_TEST_PAT",
      "Host" : "",
      "CreatedBy" : "<CREATED_BY_EMAIL>",
      "Description" : "The database job extracts curated S&P 500 market analytics from Snowflake, converts them into a single structured JSON snapshot, and pushes that file to S3 for the Bedrock agent to analyze.",
      "RunAs" : "SNOWFLAKE_TEST_PAT",
      "Application" : "SM_BEDROCK",
      "When" : {
        "WeekDays" : [ "NONE" ],
        "MonthDays" : [ "ALL" ],
        "DaysRelation" : "OR"
      },
      "eventsToAdd" : {
        "Type" : "AddEvents",
        "Events" : [ {
          "Event" : "Databases_Job-TO-Bedrock-agent-job"
        }, {
          "Event" : "Database_Job-TO-DataBrew_Validation_Job"
        } ]
      }
    }
